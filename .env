# # ============================================================
# # RevFlow — Environment Variables
# # Copy this file to .env.local and fill in all values.
# # NEVER commit .env.local to version control.
# # ============================================================

# # ────────────────────────────────────────────────────────────
# # Supabase (Required)
# # Found in: Supabase Dashboard → Project Settings → API
# # ────────────────────────────────────────────────────────────

# # Your Supabase project URL (safe to expose)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# # Anon / public key — safe to expose in browser
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# # Service role key — NEVER expose to the browser!
# # Only use in trusted server-side code if needed for admin operations.
# # SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# # ────────────────────────────────────────────────────────────
# # Razorpay (Required for payments)
# # Found in: Razorpay Dashboard → Settings → API Keys
# # ────────────────────────────────────────────────────────────

# # Public key — safe to expose in browser (used in checkout modal)
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx

# # Secret key — NEVER expose to the browser!
# # Used server-side only for creating orders and verifying signatures.
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=your-razorpay-secret-key-here

# # ────────────────────────────────────────────────────────────
# # Application (Optional)
# # ────────────────────────────────────────────────────────────

# # Full URL of your app (needed for auth redirect URLs)
# NEXT_PUBLIC_APP_URL=http://localhost:3000
